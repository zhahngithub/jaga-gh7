rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validPhoneNumber(phoneNumber) {
      return phoneNumber is string
        && phoneNumber.matches('^\\+628[1-9][0-9]{7,10}$');
    }

    function validUserFields() {
      return request.resource.data.keys().hasAll([
          'displayName',
          'email',
          'phoneNumber',
          'photoUrl',
          'helperModeEnabled',
          'communityAssistanceEnabled',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'displayName',
          'email',
          'phoneNumber',
          'photoUrl',
          'helperModeEnabled',
          'communityAssistanceEnabled',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.email is string
        && request.auth.token.email != null
        && request.resource.data.email == request.auth.token.email
        && validPhoneNumber(request.resource.data.phoneNumber)
        && (
          request.resource.data.photoUrl == null
          || request.resource.data.photoUrl is string
        )
        && request.resource.data.helperModeEnabled is bool
        && request.resource.data.communityAssistanceEnabled is bool;
    }

    function validTrustedContactFields() {
      return request.resource.data.keys().hasAll([
          'displayName',
          'phoneNumber',
          'contactUid',
          'channel',
          'status',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'displayName',
          'phoneNumber',
          'contactUid',
          'channel',
          'status',
          'createdAt'
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && validPhoneNumber(request.resource.data.phoneNumber)
        && request.resource.data.contactUid == null
        && request.resource.data.channel == 'sms'
        && request.resource.data.status == 'accepted';
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && validUserFields()
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isOwner(uid)
        && validUserFields()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'phoneNumber',
          'photoUrl',
          'helperModeEnabled',
          'communityAssistanceEnabled',
          'updatedAt'
        ])
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;

      match /trustedContacts/{contactId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && validTrustedContactFields()
          && request.resource.data.createdAt == request.time;

        allow update: if isOwner(uid)
          && validTrustedContactFields()
          && request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isOwner(uid);
      }
    }

    match /distressSessions/{sessionId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.senderUid
          || (
            resource.data.audience == 'trusted_contact'
            && resource.data.recipientUids is list
            && request.auth.uid in resource.data.recipientUids
          )
          || (
            resource.data.audience == 'nearby_helper'
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(
              /databases/$(database)/documents/users/$(request.auth.uid)
            ).data.helperModeEnabled == true
          )
        );

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'senderUid',
          'recipientUids',
          'senderDisplayName',
          'audience',
          'status',
          'preciseLocation',
          'createdAt',
          'updatedAt',
          'expiresAt'
        ])
        && request.resource.data.keys().hasOnly([
          'senderUid',
          'recipientUids',
          'senderDisplayName',
          'audience',
          'status',
          'preciseLocation',
          'createdAt',
          'updatedAt',
          'expiresAt'
        ])
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUids is list
        && request.resource.data.recipientUids.size() <= 20
        && request.resource.data.senderDisplayName is string
        && request.resource.data.senderDisplayName.size() > 0
        && request.resource.data.senderDisplayName.size() <= 80
        && request.resource.data.audience in [
          'nearby_helper',
          'trusted_contact'
        ]
        && (
          (
            request.resource.data.audience == 'nearby_helper'
            && request.resource.data.recipientUids.size() == 0
          )
          || (
            request.resource.data.audience == 'trusted_contact'
            && request.resource.data.recipientUids.size() > 0
            && !request.resource.data.recipientUids.hasAny([
              request.auth.uid
            ])
          )
        )
        && request.resource.data.status == 'active'
        && request.resource.data.preciseLocation is latlng
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.expiresAt is timestamp;

      allow update: if request.auth != null
        && resource.data.senderUid == request.auth.uid
        && resource.data.status == 'active'
        && request.resource.data.status == 'active'
        && request.resource.data.preciseLocation is latlng
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'preciseLocation',
          'updatedAt'
        ]);

      allow update: if request.auth != null
        && resource.data.senderUid == request.auth.uid
        && resource.data.status == 'active'
        && request.resource.data.status == 'ended'
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]);

      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.creatorId == request.auth.uid;

      allow delete: if false;

      allow update: if request.auth != null
        && resource.data.creatorId == request.auth.uid
        && resource.data.status == 'active'
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 500
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'updatedAt'
        ]);

      allow update: if request.auth != null
        && resource.data.creatorId == request.auth.uid
        && resource.data.status != 'deleted'
        && request.resource.data.status == 'deleted'
        && request.resource.data.deletedAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'deletedAt',
          'updatedAt'
        ]);

      match /votes/{userId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.auth.uid == userId
          && exists(/databases/$(database)/documents/reports/$(reportId))
          && get(
            /databases/$(database)/documents/reports/$(reportId)
          ).data.status != 'deleted'
          && request.resource.data.keys().hasAll([
            'value',
            'createdAt'
          ])
          && request.resource.data.keys().hasOnly([
            'value',
            'createdAt'
          ])
          && request.resource.data.value in [1, -1]
          && request.resource.data.createdAt == request.time;

        allow update: if request.auth != null
          && request.auth.uid == userId
          && exists(/databases/$(database)/documents/reports/$(reportId))
          && get(
            /databases/$(database)/documents/reports/$(reportId)
          ).data.status != 'deleted'
          && request.resource.data.keys().hasAll([
            'value',
            'createdAt'
          ])
          && request.resource.data.keys().hasOnly([
            'value',
            'createdAt'
          ])
          && request.resource.data.value in [1, -1]
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'value'
          ]);

        allow delete: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
